# Central runtime settings for submit_rnaseq.sh.
#
# This file stores the settings that commonly change between runs.
# The Slurm manager job resources still live in submit_rnaseq.sh under the
# #SBATCH lines because Slurm reads those before this file can be sourced.

# Required for Nextflow child jobs on ISAAC-NG.
export ISAAC_ACCOUNT="${ISAAC_ACCOUNT:-ACF-UTKXXXX}"

# Recommended so `sbatch submit_rnaseq.sh <dataset>` charges the manager job
# to the same account. Exported here for convenience.
export SBATCH_ACCOUNT="${SBATCH_ACCOUNT:-$ISAAC_ACCOUNT}"

# Module names on ISAAC-NG. Change these if `module avail` shows different names.
# Leave CONTAINER_MODULE empty if `singularity` is already available on PATH.
export NEXTFLOW_MODULE="${NEXTFLOW_MODULE:-nextflow}"
export CONTAINER_MODULE="${CONTAINER_MODULE:-}"

# nf-core profile for container execution on the cluster.
export NFCORE_PROFILE="${NFCORE_PROFILE:-singularity}"

# Samplesheet defaults.
export DEFAULT_STRANDEDNESS="${DEFAULT_STRANDEDNESS:-auto}"

# Scratch-backed runtime locations.
# Paths stay empty until SCRATCHDIR is available; submit_rnaseq.sh enforces it for real runs.
export RESULTS_BASE="${RESULTS_BASE:-${SCRATCHDIR:+$SCRATCHDIR/veeev_nat_hist_nfcore/results}}"
export WORK_ROOT="${WORK_ROOT:-${SCRATCHDIR:+$SCRATCHDIR/veeev_nat_hist_nfcore/work}}"
export CONTAINER_CACHE="${CONTAINER_CACHE:-${SCRATCHDIR:+$SCRATCHDIR/veeev_nat_hist_nfcore/containers}}"
export NXF_HOME="${NXF_HOME:-${SCRATCHDIR:+$SCRATCHDIR/veeev_nat_hist_nfcore/.nextflow}}"

# Viral gene_id values are set automatically from the selected virus name.
