params {
    account = System.getenv('ISAAC_ACCOUNT') ?: ''
    qos = 'campus'
    container_cache = System.getenv('CONTAINER_CACHE') ?: (System.getenv('SCRATCHDIR') ? "${System.getenv('SCRATCHDIR')}/veeev_nat_hist_nfcore/containers" : '')
}

process {
    executor = 'slurm'
    queue = 'campus'
    clusterOptions = params.account ? "--account=${params.account} --qos=${params.qos}" : "--qos=${params.qos}"

    withName: /.*STAR_ALIGN.*/ {
        cpus = 14
        memory = '45 GB'
        time = '16h'
    }

    withName: /.*STAR_GENOMEGENERATE.*/ {
        cpus = 14
        memory = '64 GB'
        time = '16h'
    }

    withName: /.*SALMON_QUANT.*/ {
        cpus = 8
        memory = '48 GB'
        time = '4h'
    }

    withName: /.*SALMON_INDEX.*/ {
        cpus = 8
        memory = '48 GB'
        time = '4h'
    }
}

executor {
    // Keep concurrent jobs modest to avoid overloading Lustre with simultaneous FASTQ reads.
    queueSize = 20
}

singularity {
    enabled = true
    autoMounts = true
    cacheDir = params.container_cache
}
